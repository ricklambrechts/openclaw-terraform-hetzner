# ============================================
# OpenClaw Application Secrets
# ============================================
# Copy to openclaw.env and fill in your values:
#   cp secrets/openclaw.env.example secrets/openclaw.env
#
# This file is the single source of truth for application secrets.
# It gets pushed to the VPS via: scripts/push-env.sh
#
# NEVER commit openclaw.env to version control.

# ============================================
# Anthropic API Key (OPTIONAL if using setup-token)
# ============================================
# Option A: API key (pay-per-use) — get at console.anthropic.com
# Option B: Claude subscription — run 'make setup-auth' instead (no key needed)
ANTHROPIC_API_KEY=

# ============================================
# REQUIRED: Telegram Bot Token
# ============================================
# Create a bot via Telegram @BotFather -> /newbot
TELEGRAM_BOT_TOKEN=

# ============================================
# REQUIRED: OpenClaw Gateway Token
# ============================================
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ============================================
# OpenClaw Gateway Settings
# ============================================
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=0.0.0.0

# ============================================
# OpenClaw Directories (on the VPS)
# ============================================
OPENCLAW_CONFIG_DIR=/home/openclaw/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/openclaw/.openclaw/workspace

# ============================================
# REQUIRED: GitHub Container Registry
# ============================================
# Your GitHub username for pulling Docker images
GHCR_USERNAME=

# ============================================
# OPTIONAL: GitHub Token (for github skill)
# ============================================
# Enables OpenClaw to interact with GitHub (PRs, issues, CI runs)
# Create a PAT at: https://github.com/settings/tokens
# Scopes needed: repo, workflow, read:org
GH_TOKEN=

# ============================================
# OPTIONAL: Brave Search API Key
# ============================================
# Get a free key at: https://brave.com/search/api/
BRAVE_API_KEY=

# ============================================
# OPTIONAL: Workspace Git Sync
# ============================================
# Daily commit+push of ~/.openclaw/workspace to a private remote git repository.
# Use one of the following options to enable:

# 1. Remote github repository in the format 'username/repo' 
# Create a PAT at: https://github.com/settings/tokens with 'repo' scope
# Auto-enables when GIT_WORKSPACE_REPO is set; redeploy to apply
# Example:
# - Repo Reference: your-username/openclaw-workspace 
GIT_WORKSPACE_REPO=
GIT_WORKSPACE_TOKEN=

# 2. other private git hosting, e.g. GitLab, Bitbucket,...
# Search how to create an inline authentication url for the provider
# Examples:
# - GitLab = https://user:token@gitlab.com/.../<repo_name>.git
# - Bitbucket = https://x-token-auth:token@bitbucket.org/.../<repo_name>.git
GIT_WORKSPACE_REMOTE=

# Configure also the branch name and cron schedule 
GIT_WORKSPACE_BRANCH=auto
# Cron schedule: minute hour day month weekday (default: daily at 4 AM UTC)

GIT_WORKSPACE_SYNC_SCHEDULE=0 4 * * *

# For multi-agent setups, add per-agent repos (see docker-compose.yml):
# GIT_WORKSPACE_REPO_SECOND=your-username/openclaw-workspace-second
# or
# GIT_WORKSPACE_REMOTE_SECOND=https://user:token@gitlab.com/username/repo-second.git

